@model List<MyWebApp.Models.UserViewDto>

@* <h2>Users</h2> *@
<a asp-action="Create" class="btn btn-primary mb-3">+ New User</a>

<table class="table table-striped">
    <thead>
        <tr><th>Username</th><th>First Name</th><th>Last Name</th><th>Email</th><th>Created</th><th></th></tr>
    </thead>
    <tbody>
    @foreach (var u in Model)
    {
        <tr>
            <td>@u.Username</td>
            <td>@u.FirstName</td>
            <td>@u.LastName</td>
            <td>@u.Email</td>
            <td>@u.CreatedAt.ToShortDateString()</td>
            <td>
                <a asp-action="Edit" asp-route-id="@u.Id" class="btn btn-sm btn-outline-secondary">Edit</a>
                <a asp-action="Delete" asp-route-id="@u.Id" class="btn btn-sm btn-outline-danger">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>