@* cshtml@model MyWebApp.Models.UserCreateDto *@

<h2>Create User</h2>
<form asp-action="Create" method="post">
    <div class="mb-3"><label>Username</label><input name="Username" class="form-control" required /></div>
    <div class="mb-3"><label>Password</label><input name="Password" type="password" class="form-control" required /></div>
    <div class="mb-3"><label>First Name</label><input name="FirstName" class="form-control" /></div>
    <div class="mb-3"><label>Last Name</label><input name="LastName" class="form-control" /></div>
    <div class="mb-3"><label>Email</label><input name="Email" type="email" class="form-control" /></div>
    <button type="submit" class="btn btn-primary">Create</button>
</form>